# Copy to .env and fill in. Never commit .env.

# Public URL of the web app (production). CORS allows this plus built-in defaults; use commas
# for multiple (e.g. Vercel prod + preview). Forgot-password uses the first entry when not on localhost.
CLIENT_URL=https://your-client.example.com

# Gmail (production-friendly): App Password required if 2FA is on.
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
# 465 + SMTP_SECURE=true (SSL), or 587 + SMTP_SECURE=false (STARTTLS)
SMTP_PORT=465
SMTP_SECURE=true
# Canonical names (optional): SMTP_USER / SMTP_PASS — or aliases:
SMTP_MAIL=
SMTP_PASSWORD=
MAIL_FROM=Chatr <you@gmail.com>

# Optional local mail catcher (dev only): point SMTP_HOST=localhost and run MailHog.
